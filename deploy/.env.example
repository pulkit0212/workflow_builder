# Copy to deploy/.env and fill in. Used by docker compose for api + web + optional bot.

# ─── URLs (browser must reach API on host port 3001 when using default compose ports)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Clerk (required for auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# ─── API-only (Express container reads these)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
GEMINI_API_KEY=
RESEND_API_KEY=
EMAIL_FROM=

# When running `docker compose --profile bot up`, set so Express can call the bot container:
# BOT_BASE_URL=http://bot:8000

# ─── Next.js server / tools (web container)
OPENAI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
