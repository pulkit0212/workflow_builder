# Optional: absolute path to legacy-bot if `process.cwd()` does not find ../backend/.../legacy-bot
# LEGACY_BOT_PATH=

# Clerk (https://dashboard.clerk.com → Application → API Keys). Both required for sign-in / ClerkProvider.
# Copy this file to .env.local and paste your pk_test_… and sk_test_… keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# PostgreSQL — matches `docker-compose.yml` defaults (npm run db:up)
DATABASE_URL=postgresql://workflow_user:password123@localhost:5432/workflow_ai
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
DEFAULT_AI_PROVIDER=mock
DEFAULT_TRANSCRIPTION_PROVIDER=mock
CLERK_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
