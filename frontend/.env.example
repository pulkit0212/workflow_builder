# ─── Clerk (required) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Express API base URL (required for browser + server Route Handlers) ─────
# Local dev: http://localhost:3001 — production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Database (if frontend scripts / Drizzle touch DB directly) ───────────────
DATABASE_URL=postgresql://localhost:5432/artivaa

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
DEFAULT_AI_PROVIDER=mock
DEFAULT_TRANSCRIPTION_PROVIDER=mock
