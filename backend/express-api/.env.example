# Server
PORT=3001
NODE_ENV=development

# Database (required)
DATABASE_URL=postgresql://localhost:5432/artivaa

# CORS — comma-separated frontend origins (required in production)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Public app URL (used in workspace invite links: /invite?token=…)
FRONTEND_URL=http://localhost:3000

# Resend transactional email (optional) — https://resend.com — workspace invites + meeting-summary auto-share (Email/Gmail integration)
# Without RESEND_API_KEY, invites still work via copy-link only; summary email falls back to Google Gmail API if OAuth includes gmail.send.
RESEND_API_KEY=
# Production: verify domain in Resend, then e.g. "Artivaa <noreply@yourdomain.com>"
# Dev / Resend test inbox: defaults to "Artivaa <onboarding@resend.dev>"
EMAIL_FROM=

# Clerk Authentication (required)
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Razorpay — payments (required for billing)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# Razorpay — webhooks (create in Razorpay Dashboard → Webhooks; use this secret for HMAC)
# Required to accept POST /api/webhooks/razorpay
RAZORPAY_WEBHOOK_SECRET=

# AI (used by routes that call Gemini, etc.)
GEMINI_API_KEY=

# Recordings
RECORDINGS_DIR=./private/recordings

# Python Bot / downstream services
BOT_BASE_URL=http://localhost:8000
# Shared secret for Mac/cloud bot to POST recordings to Render (generate: openssl rand -hex 32)
BOT_UPLOAD_SECRET=
