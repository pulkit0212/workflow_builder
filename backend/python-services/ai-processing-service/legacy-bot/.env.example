# Bot HTTP server
BOT_PORT=8000
NODE_ENV=production

# Required — same Neon pooled URL as express-api
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# AI
GEMINI_API_KEY=
OPENAI_API_KEY=

# Bot display name in meetings
BOT_NAME=Artivaa Notetaker

# Cloud / Docker: true. Local Mac debugging with visible browser: false
BOT_HEADLESS=true

# Linux audio (Render/Hetzner). Local Mac uses BlackHole — leave unset on Mac.
MEETING_AUDIO_SOURCE=default
# MEETING_MIC_SOURCE=  # optional second pulse source
