# Bot HTTP server
BOT_PORT=8000
NODE_ENV=development

# Required — same Neon pooled URL as express-api
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# AI
GEMINI_API_KEY=
OPENAI_API_KEY=

# Bot display name in meetings
BOT_NAME=Artivaa Notetaker

# Cloud / Docker: true. Local Mac: false (visible browser for Google login)
BOT_HEADLESS=false

# Mac — ffmpeg avfoundation device (ffmpeg -f avfoundation -list_devices true -i "")
# Best (Meet system audio): BlackHole 2ch — install from existential.audio/blackhole
# Quick test without BlackHole: MacBook Air Microphone  OR  :1
MEETING_AUDIO_MAC_DEVICE=MacBook Air Microphone

# Linux only (Render/Oracle)
# MEETING_AUDIO_SOURCE=default
# MEETING_MIC_SOURCE=
