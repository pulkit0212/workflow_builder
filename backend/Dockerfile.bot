# artivaa-backend repo root — Render Docker Web Service (artivaa-bot)
# Playwright + ffmpeg + Whisper (large image; first run may download Whisper weights).
FROM mcr.microsoft.com/playwright:v1.49.1-jammy

RUN apt-get update \
  && apt-get install -y --no-install-recommends ffmpeg python3-pip pulseaudio \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /bot

COPY python-services/ai-processing-service/legacy-bot/package.json \
  python-services/ai-processing-service/legacy-bot/package-lock.json ./
RUN npm ci --omit=dev

COPY python-services/ai-processing-service/legacy-bot/ ./
RUN pip3 install --no-cache-dir openai-whisper ffmpeg-python

COPY docker-entrypoint-bot.sh /usr/local/bin/docker-entrypoint-bot.sh
RUN chmod +x /usr/local/bin/docker-entrypoint-bot.sh

ENV NODE_ENV=production
ENV BOT_PORT=8000
ENV BOT_HEADLESS=true
EXPOSE 8000

ENTRYPOINT ["docker-entrypoint-bot.sh"]
